    "def normalize_df_memory(df, columns):\n",
    "    result = df.copy()\n",
    "    for col in columns:\n",
    "        min_val = df[col].min()\n",
    "        max_val = df[col].max()\n",
    "        if max_val > min_val:  \n",
    "            result[col] = (df[col] - min_val) / (max_val - min_val)\n",
    "        else:\n",
    "            result[col] = 0\n",
    "    return result\n",
