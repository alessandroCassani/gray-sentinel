    "def remove_outliers_phase_aware(df, delay_minutes=30, duration_minutes=50):\n",
    "    \"\"\"Per-phase Isolation Forest for test data with border exclusion\"\"\"\n",
    "    df_clean = df.copy()\n",
    "    df_clean = add_phase_column(df_clean, delay_minutes, duration_minutes)\n",
    "    \n",
    "    numeric_cols = [col for col in df.select_dtypes(include=[np.number]).columns \n",
    "                   if col not in ['Time', 'Minutes']]\n",
    "    outlier_stats = {}\n",
    "    \n",
    "    if len(numeric_cols) == 0:\n",
    "        return df_clean, outlier_stats\n",
    "    \n",
    "    # Define buffer zones around chaos period\n",
    "    buffer_minutes = 0.5  # Exclude 3 minutes around chaos borders\n",
    "    chaos_start = delay_minutes\n",
    "    chaos_end = delay_minutes + duration_minutes\n",
    "    \n",
    "    # Different contamination rates by phase\n",
    "    phase_contamination = {\n",
    "        'before': 0.05,   # Normal baseline cleaning\n",
    "        'during': 0.001,  # ULTRA conservative during network loss\n",
    "        'after': 0.05     # Slightly higher for recovery\n",
    "    }\n",
    "    \n",
    "    total_outliers = 0\n",
    "    \n",
    "    for phase in ['before', 'during', 'after']:\n",
    "        phase_mask = df_clean['phase'] == phase\n",
    "        phase_data = df_clean[phase_mask]\n",
    "        \n",
    "        if len(phase_data) < 10:\n",
    "            continue\n",
    "        \n",
    "        # Exclude border zones from training data for each phase\n",
    "        if phase == 'before':\n",
    "            # For before phase: exclude data too close to chaos start\n",
    "            training_mask = phase_data['Minutes'] < (chaos_start - buffer_minutes)\n",
    "        elif phase == 'during':\n",
    "            # For during phase: exclude data too close to chaos start/end\n",
    "            training_mask = (\n",
    "                (phase_data['Minutes'] > (chaos_start + buffer_minutes)) &\n",
    "                (phase_data['Minutes'] < (chaos_end - buffer_minutes))\n",
    "            )\n",
    "        else:  # after phase\n",
    "            # For after phase: exclude data too close to chaos end\n",
    "            training_mask = phase_data['Minutes'] > (chaos_end + buffer_minutes)\n",
    "        \n",
    "        # Get training data for this phase (excluding borders)\n",
    "        phase_training_data = phase_data[training_mask]\n",
    "        \n",
    "        if len(phase_training_data) < 5:\n",
    "            # Not enough training data, skip this phase or use minimal cleaning\n",
    "            outlier_stats[phase] = {\n",
    "                'count': 0,\n",
    "                'percentage': 0.0,\n",
    "                'action': 'insufficient_training_data'\n",
    "            }\n",
    "            continue\n",
    "        \n",
    "        # Train on phase data excluding borders\n",
    "        if len(numeric_cols) == 1:\n",
    "            training_matrix = phase_training_data[numeric_cols[0]].values.reshape(-1, 1)\n",
    "        else:\n",
    "            training_matrix = phase_training_data[numeric_cols].values\n",
    "        \n",
    "        training_matrix = pd.DataFrame(training_matrix).fillna(method='ffill').fillna(method='bfill').values\n",
    "        \n",
    "        if np.std(training_matrix.flatten()) == 0:\n",
    "            continue\n",
    "        \n",
    "        scaler = StandardScaler()\n",
    "        training_matrix_scaled = scaler.fit_transform(training_matrix)\n",
    "        \n",
    "        # Train model on this phase's clean data\n",
    "        contamination_rate = phase_contamination[phase]\n",
    "        iso_forest = IsolationForest(\n",
    "            contamination=contamination_rate,\n",
    "            n_estimators=100,\n",
    "            random_state=42,\n",
    "            n_jobs=-1\n",
    "        )\n",
    "        \n",
    "        iso_forest.fit(training_matrix_scaled)\n",
    "        \n",
    "        # Apply to ALL data in this phase\n",
    "        if len(numeric_cols) == 1:\n",
    "            phase_matrix = phase_data[numeric_cols[0]].values.reshape(-1, 1)\n",
    "        else:\n",
    "            phase_matrix = phase_data[numeric_cols].values\n",
    "        \n",
    "        phase_matrix = pd.DataFrame(phase_matrix).fillna(method='ffill').fillna(method='bfill').values\n",
    "        phase_matrix_scaled = scaler.transform(phase_matrix)\n",
    "        \n",
    "        outlier_predictions = iso_forest.predict(phase_matrix_scaled)\n",
    "        phase_outlier_mask = outlier_predictions == -1\n",
    "        global_outlier_indices = phase_data.index[phase_outlier_mask]\n",
    "        \n",
    "        outlier_stats[phase] = {\n",
    "            'count': phase_outlier_mask.sum(),\n",
    "            'percentage': (phase_outlier_mask.sum() / len(phase_data)) * 100,\n",
    "            'contamination_rate': contamination_rate,\n",
    "            'training_points': len(phase_training_data),\n",
    "            'excluded_border_minutes': buffer_minutes\n",
    "        }\n",
    "        \n",
    "        total_outliers += phase_outlier_mask.sum()\n",
    "        \n",
    "        for col in numeric_cols:\n",
    "            df_clean.loc[global_outlier_indices, col] = np.nan\n",
    "            phase_data_col = df_clean.loc[phase_mask, col]\n",
    "            df_clean.loc[phase_mask, col] = phase_data_col.interpolate(method='linear')\n",
    "\n",
    "    outlier_stats['_summary'] = {\n",
    "        'total_outliers': total_outliers,\n",
    "        'method': 'phase_aware_border_excluded_isolation_forest'\n",
    "    }\n",
    "    \n",
    "    return df_clean, outlier_stats\n",
